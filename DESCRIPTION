Package: pandemonium
Title: High Dimensional Analysis in Linked Spaces
Version: 0.2.4.9000
Authors@R: c(
    person("Gabriel", "McCoy",  role = c("aut", "cre"),
           email = "gabe.mccoy02@gmail.com"),
